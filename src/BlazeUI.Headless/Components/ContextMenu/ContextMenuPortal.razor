@namespace BlazeUI.Headless.Components.ContextMenu
@using BlazeUI.Headless.Overlay

<Portal ZIndex="ZIndex">
    <CascadingValue Value="Context">
        @ChildContent
    </CascadingValue>
</Portal>

@code {
    [CascadingParameter]
    internal ContextMenuContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int ZIndex { get; set; } = 1000;
}
