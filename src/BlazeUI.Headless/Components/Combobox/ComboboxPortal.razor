@namespace BlazeUI.Headless.Components.Combobox
@using BlazeUI.Headless.Overlay

<Portal ZIndex="ZIndex">
    <CascadingValue Value="Context">
        @ChildContent
    </CascadingValue>
</Portal>

@code {
    [CascadingParameter]
    internal ComboboxContext Context { get; set; } = default!;

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int ZIndex { get; set; } = 1000;
}
