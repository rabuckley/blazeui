@namespace __NAMESPACE__

<div data-slot="field-separator"
     data-content="@HasChildren.ToString().ToLowerInvariant()"
     class="@Css.Cn("relative -my-2 h-5 text-sm group-data-[variant=outline]/field-group:-mb-2", Class)"
     @attributes="AdditionalAttributes">
    <Separator Orientation="Orientation.Horizontal" Class="absolute inset-0 top-1/2" />
    @if (ChildContent is not null)
    {
        <span class="relative mx-auto block w-fit bg-background px-2 text-muted-foreground"
              data-slot="field-separator-content">
            @ChildContent
        </span>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool HasChildren => ChildContent is not null;
}
