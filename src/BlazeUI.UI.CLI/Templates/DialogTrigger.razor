@namespace __NAMESPACE__

<BlazeUI.Headless.Components.Dialog.DialogTrigger
    data-slot="dialog-trigger"
    Class="@GetClasses()"
    @attributes="AdditionalAttributes">
    @ChildContent
</BlazeUI.Headless.Components.Dialog.DialogTrigger>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public Button.ButtonVariant Variant { get; set; } = Button.ButtonVariant.Default;
    [Parameter] public Button.ButtonSize Size { get; set; } = Button.ButtonSize.Default;
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetClasses() => Css.Cn(
        ButtonClasses.Base,
        ButtonClasses.GetVariant(Variant),
        ButtonClasses.GetSize(Size),
        Class
    );
}
