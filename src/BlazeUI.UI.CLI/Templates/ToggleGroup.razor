@namespace __NAMESPACE__

@*
    ToggleGroup — wraps BlazeUI.Headless toggle group anatomy with default styling.
    Consumer passes ToggleGroupItem children for consistent toggle styling within the group.

    Usage:
    <ToggleGroup>
        <ToggleGroupItem Value="bold" aria-label="Bold">Bold</ToggleGroupItem>
        <ToggleGroupItem Value="italic" aria-label="Italic">Italic</ToggleGroupItem>
    </ToggleGroup>
*@

<BlazeUI.Headless.Components.ToggleGroup.ToggleGroupRoot
    data-slot="toggle-group"
    data-spacing="@Spacing"
    Class="@Css.Cn("group/toggle-group flex w-fit flex-row items-center gap-[--spacing(var(--gap))] rounded-lg data-[size=sm]:rounded-[min(var(--radius-md),10px)] data-vertical:flex-col data-vertical:items-stretch", Class)"
    style="@($"--gap: {Spacing}")"
    Value="@Value"
    ValueChanged="@ValueChanged"
    DefaultValue="@DefaultValue"
    Multiple="@Multiple"
    Disabled="@Disabled"
    Orientation="@Orientation"
    LoopFocus="@LoopFocus"
    @attributes="AdditionalAttributes">
    @ChildContent
</BlazeUI.Headless.Components.ToggleGroup.ToggleGroupRoot>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public IReadOnlyList<string>? Value { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<string>> ValueChanged { get; set; }
    [Parameter] public IReadOnlyList<string>? DefaultValue { get; set; }
    [Parameter] public bool Multiple { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public BlazeUI.Headless.Core.Orientation Orientation { get; set; }
    [Parameter] public bool LoopFocus { get; set; }
    [Parameter] public int Spacing { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
