@namespace __NAMESPACE__

<BlazeUI.Headless.Components.Drawer.DrawerPortal>
    <BlazeUI.Headless.Components.Drawer.DrawerBackdrop
        data-slot="drawer-overlay"
        Class="fixed inset-0 z-50 bg-black/10 supports-backdrop-filter:backdrop-blur-xs data-[open]:animate-vaul-fade-in data-[open]:fade-in-0 data-[closed]:animate-vaul-fade-out data-[closed]:pointer-events-none" />
    <BlazeUI.Headless.Components.Drawer.DrawerPopup
        data-slot="drawer-content"
        Class="@Css.Cn(
            "group/drawer-content fixed z-50 flex h-auto flex-col bg-background text-sm data-[closed]:pointer-events-none after:absolute after:bg-inherit",
            "data-[side=right]:inset-y-0 data-[side=right]:right-0 data-[side=right]:w-3/4 data-[side=right]:rounded-l-xl data-[side=right]:border-l data-[side=right]:sm:max-w-sm data-[side=right]:data-[open]:animate-vaul-slide-from-right data-[side=right]:data-[closed]:animate-vaul-slide-to-right data-[side=right]:after:inset-y-0 data-[side=right]:after:left-full data-[side=right]:after:w-[200%]",
            "data-[side=left]:inset-y-0 data-[side=left]:left-0 data-[side=left]:w-3/4 data-[side=left]:rounded-r-xl data-[side=left]:border-r data-[side=left]:sm:max-w-sm data-[side=left]:data-[open]:animate-vaul-slide-from-left data-[side=left]:data-[closed]:animate-vaul-slide-to-left data-[side=left]:after:inset-y-0 data-[side=left]:after:right-full data-[side=left]:after:w-[200%]",
            "data-[side=top]:inset-x-0 data-[side=top]:top-0 data-[side=top]:mb-24 data-[side=top]:max-h-[80vh] data-[side=top]:rounded-b-xl data-[side=top]:border-b data-[side=top]:data-[open]:animate-vaul-slide-from-top data-[side=top]:data-[closed]:animate-vaul-slide-to-top data-[side=top]:after:inset-x-0 data-[side=top]:after:bottom-full data-[side=top]:after:h-[200%]",
            "data-[side=bottom]:inset-x-0 data-[side=bottom]:bottom-0 data-[side=bottom]:mt-24 data-[side=bottom]:max-h-[80vh] data-[side=bottom]:rounded-t-xl data-[side=bottom]:border-t data-[side=bottom]:data-[open]:animate-vaul-slide-from-bottom data-[side=bottom]:data-[closed]:animate-vaul-slide-to-bottom data-[side=bottom]:after:inset-x-0 data-[side=bottom]:after:top-full data-[side=bottom]:after:h-[200%]",
            Class)">
        @* Bottom-direction drag handle — hidden for all other directions *@
        <div class="mx-auto mt-4 hidden h-1 w-[100px] shrink-0 rounded-full bg-muted group-data-[side=bottom]/drawer-content:block" />
        @ChildContent
    </BlazeUI.Headless.Components.Drawer.DrawerPopup>
</BlazeUI.Headless.Components.Drawer.DrawerPortal>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
