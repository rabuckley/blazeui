@namespace BlazeUI.Styled.Demo.Components.UI

<BlazeUI.Headless.Components.Drawer.DrawerRoot
    Open="@Open"
    OpenChanged="@OpenChanged"
    DefaultOpen="@DefaultOpen"
    SwipeDirection="@SwipeDirection">
    @ChildContent
</BlazeUI.Headless.Components.Drawer.DrawerRoot>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool? Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public BlazeUI.Headless.Core.SwipeDirection SwipeDirection { get; set; } = BlazeUI.Headless.Core.SwipeDirection.Right;
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
