@namespace BlazeUI.Styled.Demo.Components.UI

@*
    Accordion — wraps BlazeUI.Headless accordion anatomy with default styling.
    Consumer passes AccordionItem definitions as ChildContent using the headless
    sub-components directly. This template provides the styled root wrapper.

    Usage:
    <Accordion>
        <BlazeUI.Headless.Components.Accordion.AccordionItem Value="item-1" Class="not-last:border-b">
            <BlazeUI.Headless.Components.Accordion.AccordionHeader Class="flex">
                <BlazeUI.Headless.Components.Accordion.AccordionTrigger
                    Class="group/accordion-trigger relative flex flex-1 items-start justify-between rounded-lg border border-transparent py-2.5 text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 data-[disabled]:pointer-events-none data-[disabled]:opacity-50">
                    Section 1
                </BlazeUI.Headless.Components.Accordion.AccordionTrigger>
            </BlazeUI.Headless.Components.Accordion.AccordionHeader>
            <BlazeUI.Headless.Components.Accordion.AccordionPanel Class="overflow-hidden text-sm">
                <div class="pt-0 pb-2.5">Content here</div>
            </BlazeUI.Headless.Components.Accordion.AccordionPanel>
        </BlazeUI.Headless.Components.Accordion.AccordionItem>
    </Accordion>
*@

<BlazeUI.Headless.Components.Accordion.AccordionRoot
    Class="@Css.Cn("flex w-full flex-col", Class)"
    Value="@Value"
    ValueChanged="@ValueChanged"
    DefaultValue="@DefaultValue"
    Multiple="@Multiple"
    Disabled="@Disabled"
    @attributes="AdditionalAttributes">
    @ChildContent
</BlazeUI.Headless.Components.Accordion.AccordionRoot>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public IReadOnlyList<string>? Value { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<string>> ValueChanged { get; set; }
    [Parameter] public IReadOnlyList<string>? DefaultValue { get; set; }
    [Parameter] public bool Multiple { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
