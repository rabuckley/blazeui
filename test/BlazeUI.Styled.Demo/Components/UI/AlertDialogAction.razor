@namespace BlazeUI.Styled.Demo.Components.UI

@* AlertDialogAction — a styled Button for the confirm/destructive action.
   Does NOT close the dialog — the consumer handles the action and closes
   the dialog programmatically via OpenChanged binding. *@

<Button data-slot="alert-dialog-action"
        Variant="@Variant"
        Size="@Size"
        Class="@Class"
        @attributes="AdditionalAttributes">
    @ChildContent
</Button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public Button.ButtonVariant Variant { get; set; } = Button.ButtonVariant.Default;
    [Parameter] public Button.ButtonSize Size { get; set; } = Button.ButtonSize.Default;
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
