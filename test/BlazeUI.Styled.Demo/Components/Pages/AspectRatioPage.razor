@page "/aspect-ratio"

<div class="space-y-6">
<h1 class="text-2xl font-bold">Aspect Ratio</h1>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">16:9</h2>
    <div class="w-[450px]">
        <AspectRatio Ratio="@(16.0 / 9.0)">
            <div class="flex h-full items-center justify-center rounded-md bg-muted">
                <span class="text-muted-foreground">16:9</span>
            </div>
        </AspectRatio>
    </div>
</div>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">1:1</h2>
    <div class="w-[200px]">
        <AspectRatio Ratio="1">
            <div class="flex h-full items-center justify-center rounded-md bg-muted">
                <span class="text-muted-foreground">1:1</span>
            </div>
        </AspectRatio>
    </div>
</div>
</div>
