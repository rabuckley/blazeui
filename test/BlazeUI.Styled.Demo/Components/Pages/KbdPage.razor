@page "/kbd"

<div class="space-y-6">
<h1 class="text-2xl font-bold">Kbd</h1>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">Single keys</h2>
    <div class="flex items-center gap-2">
        <Kbd>⌘</Kbd>
        <Kbd>K</Kbd>
        <Kbd>Shift</Kbd>
        <Kbd>Enter</Kbd>
    </div>
</div>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">Key combinations</h2>
    <div class="flex items-center gap-1">
        <Kbd>⌘</Kbd>
        <span class="text-xs text-muted-foreground">+</span>
        <Kbd>C</Kbd>
    </div>
</div>
</div>
