@page "/progress"

<div>
<h1 class="text-2xl font-bold mb-6">Progress</h1>
<div class="max-w-md space-y-6">
    <div>
        <p class="text-sm text-muted-foreground mb-2">25%</p>
        <Progress Value="25" />
    </div>
    <div>
        <p class="text-sm text-muted-foreground mb-2">50%</p>
        <Progress Value="50" />
    </div>
    <div>
        <p class="text-sm text-muted-foreground mb-2">75%</p>
        <Progress Value="75" />
    </div>
    <div>
        <p class="text-sm text-muted-foreground mb-2">Indeterminate (null)</p>
        <Progress />
    </div>
</div>
</div>
