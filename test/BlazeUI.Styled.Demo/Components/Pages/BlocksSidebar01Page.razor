@page "/blocks/sidebar-01"
@layout BlazeUI.Styled.Demo.Components.Layout.BlocksLayout
@using BlazeUI.Styled.Demo.Components.UI
@using Microsoft.JSInterop
@inject IJSRuntime JS

<SidebarProvider>
    @* ── AppSidebar ── *@
    <SidebarComponent Collapsible="SidebarComponent.SidebarCollapsible.Icon">
        <SidebarHeader>
            @* TeamSwitcher *@
            <SidebarMenu>
                <SidebarMenuItem>
                    <DropdownMenu>
                        <DropdownMenuTrigger>
                            <Render Context="props">
                                <SidebarMenuButton Size="SidebarMenuButton.MenuButtonSize.Lg"
                                                   Class="data-open:bg-sidebar-accent data-open:text-sidebar-accent-foreground"
                                                   @attributes="props.Attributes">
                                    @props.ChildContent
                                </SidebarMenuButton>
                            </Render>
                            <ChildContent>
                                <div class="flex aspect-square size-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground">
                                    @_activeTeam.Icon
                                </div>
                                <div class="grid flex-1 text-left text-sm leading-tight">
                                    <span class="truncate font-medium">@_activeTeam.Name</span>
                                    <span class="truncate text-xs">@_activeTeam.Plan</span>
                                </div>
                                @* ChevronsUpDown icon *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto" aria-hidden="true"><path d="m7 15 5 5 5-5" /><path d="m7 9 5-5 5 5" /></svg>
                            </ChildContent>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent Class="min-w-56 rounded-lg" Align="Align.Start" Side="@(_isMobile ? Side.Bottom : Side.Right)" SideOffset="4">
                            <DropdownMenuGroup>
                                <DropdownMenuLabel Class="text-xs text-muted-foreground">Teams</DropdownMenuLabel>
                                @for (var i = 0; i < _teams.Length; i++)
                                {
                                    var team = _teams[i];
                                    var shortcut = i + 1;
                                    <DropdownMenuItem @key="team.Name" Class="gap-2 p-2" OnClick="@(() => _activeTeam = team)">
                                        <div class="flex size-6 items-center justify-center rounded-md border">
                                            @team.Icon
                                        </div>
                                        @team.Name
                                        <DropdownMenuShortcut>⌘@shortcut</DropdownMenuShortcut>
                                    </DropdownMenuItem>
                                }
                            </DropdownMenuGroup>
                            <DropdownMenuSeparator />
                            <DropdownMenuGroup>
                                <DropdownMenuItem Class="gap-2 p-2">
                                    <div class="flex size-6 items-center justify-center rounded-md border bg-transparent">
                                        @* Plus icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true"><path d="M5 12h14" /><path d="M12 5v14" /></svg>
                                    </div>
                                    <div class="font-medium text-muted-foreground">Add team</div>
                                </DropdownMenuItem>
                            </DropdownMenuGroup>
                        </DropdownMenuContent>
                    </DropdownMenu>
                </SidebarMenuItem>
            </SidebarMenu>
        </SidebarHeader>

        <SidebarContent>
            @* ── NavMain (collapsible sections) ── *@
            <SidebarGroup>
                <SidebarGroupLabel>Platform</SidebarGroupLabel>
                <SidebarMenu>
                    @foreach (var item in _navMain)
                    {
                        <BlazeUI.Headless.Components.Collapsible.CollapsibleRoot @key="item.Title"
                            As="li" DefaultOpen="@item.IsActive"
                            Class="group/menu-item relative group/collapsible"
                            data-slot="collapsible" data-sidebar="menu-item">
                                <CollapsibleTrigger>
                                    <Render Context="props">
                                        <SidebarMenuButton @attributes="props.Attributes">
                                            @props.ChildContent
                                        </SidebarMenuButton>
                                    </Render>
                                    <ChildContent>
                                        @item.Icon
                                        <span>@item.Title</span>
                                        @* ChevronRight icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto transition-transform duration-200 group-data-open/collapsible:rotate-90" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
                                    </ChildContent>
                                </CollapsibleTrigger>
                                <CollapsibleContent>
                                    <SidebarMenuSub>
                                        @foreach (var sub in item.Items)
                                        {
                                            <SidebarMenuSubItem>
                                                <SidebarMenuSubButton Href="#">
                                                    <span>@sub</span>
                                                </SidebarMenuSubButton>
                                            </SidebarMenuSubItem>
                                        }
                                    </SidebarMenuSub>
                                </CollapsibleContent>
                        </BlazeUI.Headless.Components.Collapsible.CollapsibleRoot>
                    }
                </SidebarMenu>
            </SidebarGroup>

            @* ── NavProjects ── *@
            <SidebarGroup Class="group-data-[collapsible=icon]:hidden">
                <SidebarGroupLabel>Projects</SidebarGroupLabel>
                <SidebarMenu>
                    @foreach (var project in _projects)
                    {
                        <SidebarMenuItem @key="project.Name">
                            <SidebarMenuButton Href="#">
                                @project.Icon
                                <span>@project.Name</span>
                            </SidebarMenuButton>
                            <DropdownMenu>
                                <DropdownMenuTrigger>
                                    <Render Context="props">
                                        <SidebarMenuAction ShowOnHover="true" Class="aria-expanded:bg-muted" @attributes="props.Attributes">
                                            @props.ChildContent
                                        </SidebarMenuAction>
                                    </Render>
                                    <ChildContent>
                                        @* MoreHorizontal icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="1" /><circle cx="19" cy="12" r="1" /><circle cx="5" cy="12" r="1" /></svg>
                                        <span class="sr-only">More</span>
                                    </ChildContent>
                                </DropdownMenuTrigger>
                                <DropdownMenuContent Class="w-48 rounded-lg" Side="@(_isMobile ? Side.Bottom : Side.Right)" Align="@(_isMobile ? Align.End : Align.Start)">
                                    <DropdownMenuItem>
                                        @* Folder icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden="true"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" /></svg>
                                        <span>View Project</span>
                                    </DropdownMenuItem>
                                    <DropdownMenuItem>
                                        @* ArrowRight icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden="true"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
                                        <span>Share Project</span>
                                    </DropdownMenuItem>
                                    <DropdownMenuSeparator />
                                    <DropdownMenuItem>
                                        @* Trash2 icon *@
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden="true"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line x1="10" x2="10" y1="11" y2="17" /><line x1="14" x2="14" y1="11" y2="17" /></svg>
                                        <span>Delete Project</span>
                                    </DropdownMenuItem>
                                </DropdownMenuContent>
                            </DropdownMenu>
                        </SidebarMenuItem>
                    }
                    <SidebarMenuItem>
                        <SidebarMenuButton Class="text-sidebar-foreground/70">
                            @* MoreHorizontal icon *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sidebar-foreground/70" aria-hidden="true"><circle cx="12" cy="12" r="1" /><circle cx="19" cy="12" r="1" /><circle cx="5" cy="12" r="1" /></svg>
                            <span>More</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                </SidebarMenu>
            </SidebarGroup>
        </SidebarContent>

        <SidebarFooter>
            @* ── NavUser ── *@
            <SidebarMenu>
                <SidebarMenuItem>
                    <DropdownMenu>
                        <DropdownMenuTrigger>
                            <Render Context="props">
                                <SidebarMenuButton Size="SidebarMenuButton.MenuButtonSize.Lg"
                                                   Class="aria-expanded:bg-muted"
                                                   @attributes="props.Attributes">
                                    @props.ChildContent
                                </SidebarMenuButton>
                            </Render>
                            <ChildContent>
                                <Avatar>
                                    <AvatarImage Src="/avatars/shadcn.jpg" Alt="shadcn" />
                                    <AvatarFallback>CN</AvatarFallback>
                                </Avatar>
                                <div class="grid flex-1 text-left text-sm leading-tight">
                                    <span class="truncate font-medium">shadcn</span>
                                    <span class="truncate text-xs">m@("@")example.com</span>
                                </div>
                                @* ChevronsUpDown icon *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto size-4" aria-hidden="true"><path d="m7 15 5 5 5-5" /><path d="m7 9 5-5 5 5" /></svg>
                            </ChildContent>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent Class="min-w-56 rounded-lg" Side="@(_isMobile ? Side.Bottom : Side.Right)" Align="Align.End" SideOffset="4">
                            <DropdownMenuGroup>
                                <DropdownMenuLabel Class="p-0 font-normal">
                                    <div class="flex items-center gap-2 px-1 py-1.5 text-left text-sm">
                                        <Avatar>
                                            <AvatarImage Src="/avatars/shadcn.jpg" Alt="shadcn" />
                                            <AvatarFallback>CN</AvatarFallback>
                                        </Avatar>
                                        <div class="grid flex-1 text-left text-sm leading-tight">
                                            <span class="truncate font-medium">shadcn</span>
                                            <span class="truncate text-xs">m@("@")example.com</span>
                                        </div>
                                    </div>
                                </DropdownMenuLabel>
                            </DropdownMenuGroup>
                            <DropdownMenuSeparator />
                            <DropdownMenuGroup>
                                <DropdownMenuItem>
                                    @* Sparkles icon *@
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" /><path d="M20 3v4" /><path d="M22 5h-4" /><path d="M4 17v2" /><path d="M5 18H3" /></svg>
                                    Upgrade to Pro
                                </DropdownMenuItem>
                            </DropdownMenuGroup>
                            <DropdownMenuSeparator />
                            <DropdownMenuGroup>
                                <DropdownMenuItem>
                                    @* BadgeCheck icon *@
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" /><path d="m9 12 2 2 4-4" /></svg>
                                    Account
                                </DropdownMenuItem>
                                <DropdownMenuItem>
                                    @* CreditCard icon *@
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2" /><line x1="2" x2="22" y1="10" y2="10" /></svg>
                                    Billing
                                </DropdownMenuItem>
                                <DropdownMenuItem>
                                    @* Bell icon *@
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" /><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" /></svg>
                                    Notifications
                                </DropdownMenuItem>
                            </DropdownMenuGroup>
                            <DropdownMenuSeparator />
                            <DropdownMenuItem>
                                @* LogOut icon *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" /></svg>
                                Log out
                            </DropdownMenuItem>
                        </DropdownMenuContent>
                    </DropdownMenu>
                </SidebarMenuItem>
            </SidebarMenu>
        </SidebarFooter>
        <SidebarRail />
    </SidebarComponent>

    @* ── Main content ── *@
    <SidebarInset>
        <header class="flex h-16 shrink-0 items-center gap-2 border-b px-4">
            <SidebarTrigger Class="-ml-1" />
            <Separator Orientation="Orientation.Vertical" Class="mr-2 h-4" />
            <Breadcrumb>
                <BreadcrumbList>
                    <BreadcrumbItem Class="hidden md:block">
                        <BreadcrumbLink href="#">Build Your Application</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator Class="hidden md:block" />
                    <BreadcrumbItem>
                        <BlazeUI.Styled.Demo.Components.UI.BreadcrumbPage>Data Fetching</BlazeUI.Styled.Demo.Components.UI.BreadcrumbPage>
                    </BreadcrumbItem>
                </BreadcrumbList>
            </Breadcrumb>
        </header>
        <div class="flex flex-1 flex-col gap-4 p-4">
            <div class="grid auto-rows-min gap-4 md:grid-cols-3">
                <div class="aspect-video rounded-xl bg-muted/50" />
                <div class="aspect-video rounded-xl bg-muted/50" />
                <div class="aspect-video rounded-xl bg-muted/50" />
            </div>
            <div class="min-h-[100vh] flex-1 rounded-xl bg-muted/50 md:min-h-min" />
        </div>
    </SidebarInset>
</SidebarProvider>

@code {
    private bool _isMobile;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await JS.InvokeAsync<bool>("eval", "window.innerWidth < 768");
            StateHasChanged();
        }
    }

    private record TeamInfo(string Name, string Plan, RenderFragment Icon);
    private record NavMainItem(string Title, RenderFragment Icon, bool IsActive, string[] Items);
    private record ProjectInfo(string Name, RenderFragment Icon);

    private TeamInfo _activeTeam = null!;

    private static readonly RenderFragment GalleryVerticalEndIcon = @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 2h10"></path><path d="M5 6h14"></path><rect width="18" height="12" x="3" y="10" rx="2"></rect></svg>;
    private static readonly RenderFragment AudioLinesIcon = @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 10v3"></path><path d="M6 6v11"></path><path d="M10 3v18"></path><path d="M14 8v7"></path><path d="M18 5v13"></path><path d="M22 10v3"></path></svg>;
    private static readonly RenderFragment TerminalIcon = @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19h8"></path><path d="m4 17 6-6-6-6"></path></svg>;

    private TeamInfo[] _teams = null!;
    private NavMainItem[] _navMain = null!;
    private ProjectInfo[] _projects = null!;

    protected override void OnInitialized()
    {
        _teams =
        [
            new("Acme Inc", "Enterprise", GalleryVerticalEndIcon),
            new("Acme Corp.", "Startup", AudioLinesIcon),
            new("Evil Corp.", "Free", TerminalIcon),
        ];
        _activeTeam = _teams[0];

        _navMain =
        [
            new("Playground",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7 11 2-2-2-2" /><path d="M11 13h4" /><rect width="18" height="18" x="3" y="3" rx="2" ry="2" /></svg>,
                true, ["History", "Starred", "Settings"]),
            new("Models",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8V4H8" /><rect width="16" height="12" x="4" y="8" rx="2" /><path d="M2 14h2" /><path d="M20 14h2" /><path d="M15 13v2" /><path d="M9 13v2" /></svg>,
                false, ["Genesis", "Explorer", "Quantum"]),
            new("Documentation",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 7v14" /><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" /></svg>,
                false, ["Introduction", "Get Started", "Tutorials", "Changelog"]),
            new("Settings",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 17H5"></path><path d="M19 7h-9"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg>,
                false, ["General", "Team", "Billing", "Limits"]),
        ];

        _projects =
        [
            new("Design Engineering",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" x2="2" y1="6" y2="6" /><line x1="22" x2="2" y1="18" y2="18" /><line x1="6" x2="6" y1="2" y2="22" /><line x1="18" x2="18" y1="2" y2="22" /></svg>),
            new("Sales & Marketing",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12c.552 0 1.005-.449.95-.998a10 10 0 0 0-8.953-8.951c-.55-.055-.998.398-.998.95v8a1 1 0 0 0 1 1z"></path><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path></svg>),
            new("Travel",
                @<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z" /><path d="M15 5.764v15" /><path d="M9 3.236v15" /></svg>),
        ];
    }
}
