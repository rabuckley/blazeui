@page "/checkbox"

<div>
    <h1 class="text-2xl font-bold mb-6">Checkbox</h1>
    <div class="space-y-4">
        <div class="flex items-center gap-2">
            <Checkbox id="terms" DefaultChecked="true" />
            <label for="terms" class="text-sm">Accept terms and conditions</label>
        </div>
        <div class="flex items-center gap-2">
            <Checkbox id="unchecked" />
            <label for="unchecked" class="text-sm">Unchecked by default</label>
        </div>
        <div class="flex items-center gap-2">
            <Checkbox id="disabled" Disabled="true" />
            <label for="disabled" class="text-sm text-muted-foreground">Disabled</label>
        </div>
    </div>
</div>
