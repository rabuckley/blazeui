@page "/select"

<div class="space-y-6">
<h1 class="text-2xl font-bold">Select</h1>

<div class="max-w-xs">
    <Select Placeholder="Choose a fruit...">
        <SelectTrigger>
            <SelectValue />
        </SelectTrigger>
        <SelectContent>
            <SelectItem Value="apple">Apple</SelectItem>
            <SelectItem Value="banana">Banana</SelectItem>
            <SelectItem Value="cherry">Cherry</SelectItem>
        </SelectContent>
    </Select>
</div>
</div>
