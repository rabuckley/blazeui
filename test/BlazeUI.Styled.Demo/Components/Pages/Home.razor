@page "/"

<h1 class="text-2xl font-bold mb-8">BlazeUI Component Showcase</h1>

<div class="space-y-8">
    <section>
        <h2 class="text-lg font-medium mb-3 text-muted-foreground">Simple</h2>
        <div class="grid grid-cols-3 gap-2">
            <a href="/button" class="rounded-md border p-3 hover:bg-accent transition-colors">Button</a>
            <a href="/input" class="rounded-md border p-3 hover:bg-accent transition-colors">Input</a>
            <a href="/checkbox" class="rounded-md border p-3 hover:bg-accent transition-colors">Checkbox</a>
            <a href="/switch" class="rounded-md border p-3 hover:bg-accent transition-colors">Switch</a>
            <a href="/toggle" class="rounded-md border p-3 hover:bg-accent transition-colors">Toggle</a>
            <a href="/separator" class="rounded-md border p-3 hover:bg-accent transition-colors">Separator</a>
            <a href="/progress" class="rounded-md border p-3 hover:bg-accent transition-colors">Progress</a>
            <a href="/avatar" class="rounded-md border p-3 hover:bg-accent transition-colors">Avatar</a>
            <a href="/meter" class="rounded-md border p-3 hover:bg-accent transition-colors">Meter</a>
            <a href="/slider" class="rounded-md border p-3 hover:bg-accent transition-colors">Slider</a>
            <a href="/number-field" class="rounded-md border p-3 hover:bg-accent transition-colors">NumberField</a>
            <a href="/radio" class="rounded-md border p-3 hover:bg-accent transition-colors">Radio</a>
            <a href="/checkbox-group" class="rounded-md border p-3 hover:bg-accent transition-colors">CheckboxGroup</a>
            <a href="/toggle-group" class="rounded-md border p-3 hover:bg-accent transition-colors">ToggleGroup</a>
        </div>
    </section>

    <section>
        <h2 class="text-lg font-medium mb-3 text-muted-foreground">Overlay</h2>
        <div class="grid grid-cols-3 gap-2">
            <a href="/dialog" class="rounded-md border p-3 hover:bg-accent transition-colors">Dialog</a>
            <a href="/alert-dialog" class="rounded-md border p-3 hover:bg-accent transition-colors">AlertDialog</a>
            <a href="/drawer" class="rounded-md border p-3 hover:bg-accent transition-colors">Drawer</a>
            <a href="/menu" class="rounded-md border p-3 hover:bg-accent transition-colors">Menu</a>
            <a href="/context-menu" class="rounded-md border p-3 hover:bg-accent transition-colors">ContextMenu</a>
            <a href="/popover" class="rounded-md border p-3 hover:bg-accent transition-colors">Popover</a>
            <a href="/tooltip" class="rounded-md border p-3 hover:bg-accent transition-colors">Tooltip</a>
            <a href="/preview-card" class="rounded-md border p-3 hover:bg-accent transition-colors">PreviewCard</a>
            <a href="/select" class="rounded-md border p-3 hover:bg-accent transition-colors">Select</a>
            <a href="/combobox" class="rounded-md border p-3 hover:bg-accent transition-colors">Combobox</a>
            <a href="/autocomplete" class="rounded-md border p-3 hover:bg-accent transition-colors">Autocomplete</a>

            <a href="/toast" class="rounded-md border p-3 hover:bg-accent transition-colors">Toast</a>
        </div>
    </section>

    <section>
        <h2 class="text-lg font-medium mb-3 text-muted-foreground">Layout</h2>
        <div class="grid grid-cols-3 gap-2">
            <a href="/accordion" class="rounded-md border p-3 hover:bg-accent transition-colors">Accordion</a>
            <a href="/tabs" class="rounded-md border p-3 hover:bg-accent transition-colors">Tabs</a>
            <a href="/collapsible" class="rounded-md border p-3 hover:bg-accent transition-colors">Collapsible</a>
            <a href="/toolbar" class="rounded-md border p-3 hover:bg-accent transition-colors">Toolbar</a>
            <a href="/menubar" class="rounded-md border p-3 hover:bg-accent transition-colors">Menubar</a>
            <a href="/navigation-menu" class="rounded-md border p-3 hover:bg-accent transition-colors">NavigationMenu</a>
            <a href="/scroll-area" class="rounded-md border p-3 hover:bg-accent transition-colors">ScrollArea</a>
        </div>
    </section>

    <section>
        <h2 class="text-lg font-medium mb-3 text-muted-foreground">Form</h2>
        <div class="grid grid-cols-3 gap-2">
            <a href="/field" class="rounded-md border p-3 hover:bg-accent transition-colors">Field</a>
            <a href="/fieldset" class="rounded-md border p-3 hover:bg-accent transition-colors">Fieldset</a>
            <a href="/form" class="rounded-md border p-3 hover:bg-accent transition-colors">Form</a>
        </div>
    </section>
</div>
