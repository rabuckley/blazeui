@page "/slider"

<div>
    <h1 class="text-2xl font-bold mb-6">Slider</h1>
    <div class="max-w-md space-y-6">
        <div>
            <p class="text-sm text-muted-foreground mb-2">Default (50)</p>
            <Slider DefaultValue="50" />
        </div>
        <div>
            <p class="text-sm text-muted-foreground mb-2">Step = 10</p>
            <Slider DefaultValue="30" Step="10" />
        </div>
        <div>
            <p class="text-sm text-muted-foreground mb-2">Disabled</p>
            <Slider DefaultValue="40" Disabled="true" />
        </div>
    </div>
</div>
