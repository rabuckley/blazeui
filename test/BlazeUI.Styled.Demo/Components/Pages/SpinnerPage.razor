@page "/spinner"

<div class="space-y-6">
<h1 class="text-2xl font-bold">Spinner</h1>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">Default</h2>
    <Spinner />
</div>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">Custom size</h2>
    <div class="flex items-center gap-4">
        <Spinner Class="size-4" />
        <Spinner Class="size-6" />
        <Spinner Class="size-8" />
    </div>
</div>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">With button</h2>
    <Button Disabled="true">
        <Spinner Class="size-4" />
        Loading...
    </Button>
</div>
</div>
