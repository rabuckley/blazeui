@page "/empty"

<div class="space-y-6">
<h1 class="text-2xl font-bold">Empty</h1>

<div>
    <h2 class="text-sm font-medium text-muted-foreground mb-3">Default</h2>
    <Empty Class="border">
        <EmptyHeader>
            <EmptyMedia Variant="EmptyMedia.EmptyMediaVariant.Icon">
                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 8V5c0-1 1-2 2-2h10c1 0 2 1 2 2v3"/><path d="M19 16v3c0 1-1 2-2 2H7c-1 0-2-1-2-2v-3"/><line x1="4" x2="20" y1="12" y2="12"/>
                </svg>
            </EmptyMedia>
            <EmptyTitle>No items found</EmptyTitle>
            <EmptyDescription>Get started by creating your first item.</EmptyDescription>
        </EmptyHeader>
        <EmptyContent>
            <Button>Create item</Button>
        </EmptyContent>
    </Empty>
</div>
</div>
