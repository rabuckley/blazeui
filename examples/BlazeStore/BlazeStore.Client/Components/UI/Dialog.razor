@namespace BlazeStore.Client.Components.UI

<BlazeUI.Headless.Components.Dialog.DialogRoot Open="@Open" OpenChanged="@OpenChanged" DefaultOpen="@DefaultOpen">
    @if (Trigger is not null)
    {
        <BlazeUI.Headless.Components.Dialog.DialogTrigger
            Class="@GetTriggerClasses()"
            data-slot="dialog-trigger">
            @Trigger
        </BlazeUI.Headless.Components.Dialog.DialogTrigger>
    }
    <BlazeUI.Headless.Components.Dialog.DialogPortal>
        <BlazeUI.Headless.Components.Dialog.DialogBackdrop
            Class="fixed inset-0 z-50 bg-black/50 data-[open]:animate-in data-[open]:fade-in-0 data-[closed]:animate-out data-[closed]:fade-out-0 data-[closed]:hidden" />
        <BlazeUI.Headless.Components.Dialog.DialogPopup
            Class="fixed left-1/2 top-1/2 z-50 grid w-full max-w-lg -translate-x-1/2 -translate-y-1/2 gap-4 border bg-background p-6 shadow-lg duration-200 data-[open]:animate-in data-[open]:fade-in-0 data-[open]:zoom-in-95 data-[closed]:animate-out data-[closed]:fade-out-0 data-[closed]:zoom-out-95 data-[closed]:hidden sm:rounded-lg">
            <div class="flex flex-col space-y-1.5 text-center sm:text-left">
                @if (Title is not null)
                {
                    <BlazeUI.Headless.Components.Dialog.DialogTitle
                        Class="text-base leading-none font-medium">
                        @Title
                    </BlazeUI.Headless.Components.Dialog.DialogTitle>
                }
                @if (Description is not null)
                {
                    <BlazeUI.Headless.Components.Dialog.DialogDescription
                        Class="text-sm text-muted-foreground">
                        @Description
                    </BlazeUI.Headless.Components.Dialog.DialogDescription>
                }
            </div>
            @ChildContent
            <BlazeUI.Headless.Components.Dialog.DialogClose
                Class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
                <span class="sr-only">Close</span>
            </BlazeUI.Headless.Components.Dialog.DialogClose>
        </BlazeUI.Headless.Components.Dialog.DialogPopup>
    </BlazeUI.Headless.Components.Dialog.DialogPortal>
</BlazeUI.Headless.Components.Dialog.DialogRoot>

@code {
    [Parameter] public RenderFragment? Trigger { get; set; }
    [Parameter] public RenderFragment? Title { get; set; }
    [Parameter] public RenderFragment? Description { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool? Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public string? TriggerClass { get; set; }
    [Parameter] public Button.ButtonVariant TriggerVariant { get; set; } = Button.ButtonVariant.Default;
    [Parameter] public Button.ButtonSize TriggerSize { get; set; } = Button.ButtonSize.Default;
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetTriggerClasses() => Css.Cn(
        ButtonClasses.Base,
        ButtonClasses.GetVariant(TriggerVariant),
        ButtonClasses.GetSize(TriggerSize),
        TriggerClass
    );
}
