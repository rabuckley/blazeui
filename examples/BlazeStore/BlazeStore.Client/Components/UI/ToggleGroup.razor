@namespace BlazeStore.Client.Components.UI

@*
    ToggleGroup — wraps BlazeUI.Headless toggle group anatomy with default styling.
    Consumer passes headless ToggleRoot items as ChildContent. Use the styled Toggle component
    for consistent toggle styling within the group.

    Usage:
    <ToggleGroup>
        <Toggle>Bold</Toggle>
        <Toggle>Italic</Toggle>
    </ToggleGroup>
*@

<BlazeUI.Headless.Components.ToggleGroup.ToggleGroupRoot
    Class="@Css.Cn("group/toggle-group flex w-fit flex-row items-center gap-0 rounded-lg [&>*]:shrink-0 [&>*]:rounded-none [&>*:first-child]:rounded-l-lg [&>*:last-child]:rounded-r-lg", Class)"
    Value="@Value"
    ValueChanged="@ValueChanged"
    DefaultValue="@DefaultValue"
    Multiple="@Multiple"
    Disabled="@Disabled"
    Orientation="@Orientation"
    LoopFocus="@LoopFocus"
    @attributes="AdditionalAttributes">
    @ChildContent
</BlazeUI.Headless.Components.ToggleGroup.ToggleGroupRoot>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public IReadOnlyList<string>? Value { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<string>> ValueChanged { get; set; }
    [Parameter] public IReadOnlyList<string>? DefaultValue { get; set; }
    [Parameter] public bool Multiple { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public BlazeUI.Headless.Core.Orientation Orientation { get; set; }
    [Parameter] public bool LoopFocus { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
