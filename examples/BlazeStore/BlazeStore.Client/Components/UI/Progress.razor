@namespace BlazeStore.Client.Components.UI

<BlazeUI.Headless.Components.Progress.ProgressRoot
    Class="@Css.Cn("flex flex-wrap gap-3", Class)"
    Value="@Value"
    Min="@Min"
    Max="@Max"
    @attributes="AdditionalAttributes">
    <BlazeUI.Headless.Components.Progress.ProgressTrack Class="relative flex h-1 w-full items-center overflow-x-hidden rounded-full bg-muted">
        <BlazeUI.Headless.Components.Progress.ProgressIndicator
            Class="h-full bg-primary transition-all" />
    </BlazeUI.Headless.Components.Progress.ProgressTrack>
</BlazeUI.Headless.Components.Progress.ProgressRoot>

@code {
    [Parameter] public double? Value { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
